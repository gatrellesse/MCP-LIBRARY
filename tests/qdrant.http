@base = http://localhost:6333
@collection = books

### Health check
GET {{base}}/healthz

### List all collections
GET {{base}}/collections

### Create books collection (run this if collection doesn't exist yet)
PUT {{base}}/collections/{{collection}}
Content-Type: application/json

{
  "vectors": {
    "synopsis": {
      "size": 384,
      "distance": "Cosine"
    }
  }
}

### Create payload indexes
PUT {{base}}/collections/{{collection}}/index
Content-Type: application/json

{
  "field_name": "user_id",
  "field_schema": "keyword"
}

###
PUT {{base}}/collections/{{collection}}/index
Content-Type: application/json

{
  "field_name": "status",
  "field_schema": "keyword"
}

###
PUT {{base}}/collections/{{collection}}/index
Content-Type: application/json

{
  "field_name": "genre",
  "field_schema": "keyword"
}

### Get collection info
GET {{base}}/collections/{{collection}}

### Insert a book (with a fake 384-dim synopsis vector — replace with a real embedding)
PUT {{base}}/collections/{{collection}}/points
Content-Type: application/json

{
  "points": [
    {
      "id": "11111111-1111-1111-1111-111111111111",
      "vector": {
        "synopsis": [0.1, 0.2, 0.3]
      },
      "payload": {
        "user_id": "user_abc",
        "title": "The Hobbit",
        "author": "J.R.R. Tolkien",
        "genre": "fantasy",
        "synopsis": "A hobbit goes on an unexpected journey with a group of dwarves.",
        "status": "finished",
        "has_text_embedding": false
      }
    }
  ]
}

### Insert a second book
PUT {{base}}/collections/{{collection}}/points
Content-Type: application/json

{
  "points": [
    {
      "id": "22222222-2222-2222-2222-222222222222",
      "vector": {
        "synopsis": [0.15, 0.25, 0.35]
      },
      "payload": {
        "user_id": "user_abc",
        "title": "1984",
        "author": "George Orwell",
        "genre": "dystopia",
        "synopsis": "A man lives under a totalitarian regime that controls reality itself.",
        "status": "reading",
        "has_text_embedding": false
      }
    }
  ]
}

### Search by synopsis similarity (filtered by user_id)
POST {{base}}/collections/{{collection}}/points/search
Content-Type: application/json

{
  "vector": {
    "name": "synopsis",
    "vector": [0.1, 0.2, 0.3]
  },
  "filter": {
    "must": [
      { "key": "user_id", "match": { "value": "user_abc" } }
    ]
  },
  "limit": 5,
  "with_payload": true
}

### Search filtered by user_id + status
POST {{base}}/collections/{{collection}}/points/search
Content-Type: application/json

{
  "vector": {
    "name": "synopsis",
    "vector": [0.1, 0.2, 0.3]
  },
  "filter": {
    "must": [
      { "key": "user_id", "match": { "value": "user_abc" } },
      { "key": "status", "match": { "value": "reading" } }
    ]
  },
  "limit": 5,
  "with_payload": true
}

### Search filtered by user_id + genre
POST {{base}}/collections/{{collection}}/points/search
Content-Type: application/json

{
  "vector": {
    "name": "synopsis",
    "vector": [0.1, 0.2, 0.3]
  },
  "filter": {
    "must": [
      { "key": "user_id", "match": { "value": "user_abc" } },
      { "key": "genre", "match": { "value": "fantasy" } }
    ]
  },
  "limit": 5,
  "with_payload": true
}

### Get a specific book by ID
GET {{base}}/collections/{{collection}}/points/11111111-1111-1111-1111-111111111111

### Update status of a book
POST {{base}}/collections/{{collection}}/points/payload
Content-Type: application/json

{
  "payload": { "status": "finished" },
  "points": ["22222222-2222-2222-2222-222222222222"]
}

### List all books for a user (scroll, no vector needed)
POST {{base}}/collections/{{collection}}/points/scroll
Content-Type: application/json

{
  "filter": {
    "must": [
      { "key": "user_id", "match": { "value": "user_abc" } }
    ]
  },
  "with_payload": true,
  "limit": 100
}

### Delete a book
POST {{base}}/collections/{{collection}}/points/delete
Content-Type: application/json

{
  "points": ["22222222-2222-2222-2222-222222222222"]
}

### Delete the collection (destructive!)
DELETE {{base}}/collections/{{collection}}
